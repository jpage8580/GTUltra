# Object files
*.o
*.d

# Built binaries
mac/
linux/
win32/*.exe
win32/*.dll

# Generated source
src/goatdata.c
src/gt2stereo.dat

# Generated build tools
src/bme/datafile
src/bme/dat2inc

# OS artifacts
.DS_Store

# Debug artifacts
examples/*/debug_*.s

# Packed player outputs (generated by gt2reloc / the editor; only .sng source fixtures are tracked)
tests/fixtures/*.sid
tests/fixtures/*.prg

# Golden-reference audio: rendered locally by sng2wav, NOT committed (large binaries +
# examples/ tunes are third-party). Track the corpus list + hashes/metrics instead.
tests/fixtures/*.wav
tests/fixtures/golden/
# Golden manifest is per-build/per-arch (reSID float output), so it is an M1 same-env
# gate, not a committed cross-platform reference. tests/golden/corpus.txt IS tracked.
tests/golden/manifest.sha256

# Unit-test build artifacts (harness header tests/unit/greatest.h stays tracked)
tests/unit/run_tests
tests/unit/run_tests.exe
tests/unit/*.dSYM/

# local ai
.claude/settings.local.json
.devin/

# upstream SID engine sources cloned for reference during migration (not vendored)
_upstream/
